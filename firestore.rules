rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function dbPath(path) {
      return /databases/$(database)/documents + path;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Collection validators
    function isValidProfile(data) {
      return true;
    }

    function isValidMember(data) {
      return true;
    }

    function isValidMemberNote(data) {
      return true;
    }

    function isValidPrayerRequest(data) {
      return true;
    }

    function isValidFollowUpLog(data) {
      return true;
    }

    function isValidSmallGroup(data) {
      return true;
    }

    function isValidMeetingLog(data) {
      return true;
    }

    function isValidMaterial(data) {
      return true;
    }

    function isValidTransaction(data) {
      return true;
    }

    function isValidFinancialCategory(data) {
      return true;
    }

    function isValidPartner(data) {
      return true;
    }

    function isValidDonation(data) {
      return true;
    }

    function isValidStaff(data) {
      return true;
    }

    function isValidSalary(data) {
      return true;
    }

    function isValidLetterInward(data) {
      return true;
    }

    function isValidLetterOutward(data) {
      return true;
    }

    // Documents validator
    function isValidOrgDocument(data) {
      return true;
    }

    // Approval Request validator
    function isValidApproval(data) {
      return true;
    }

    function isValidAudit(data) {
      return true;
    }

    function isValidKas(data) {
      return true;
    }

    function isValidStructure(data) {
      return true;
    }

    // All-matching Firestore Collections Security Rules
    match /profiles/{profileId} {
      allow read: if true;
      allow create, update: if isValidId(profileId) && isValidProfile(incoming());
      allow delete: if true;
    }

    match /users/{email} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /members/{memberId} {
      allow read: if true;
      allow create, update: if isValidId(memberId) && isValidMember(incoming());
      allow delete: if true;
    }

    match /member_notes/{noteId} {
      allow read: if true;
      allow create, update: if isValidId(noteId) && isValidMemberNote(incoming());
      allow delete: if true;
    }

    match /prayer_requests/{requestId} {
      allow read: if true;
      allow create, update: if isValidId(requestId) && isValidPrayerRequest(incoming());
      allow delete: if true;
    }

    match /follow_ups/{followUpId} {
      allow read: if true;
      allow create, update: if isValidId(followUpId) && isValidFollowUpLog(incoming());
      allow delete: if true;
    }

    match /small_groups/{groupId} {
      allow read: if true;
      allow create, update: if isValidId(groupId) && isValidSmallGroup(incoming());
      allow delete: if true;
    }

    match /meeting_logs/{logId} {
      allow read: if true;
      allow create, update: if isValidId(logId) && isValidMeetingLog(incoming());
      allow delete: if true;
    }

    match /materials/{materialId} {
      allow read: if true;
      allow create, update: if isValidId(materialId) && isValidMaterial(incoming());
      allow delete: if true;
    }

    match /transactions/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if true;
    }

    match /financial_transactions/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if true;
    }

    match /incomes/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if true;
    }

    match /expenses/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if true;
    }

    match /fundraising/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if true;
    }

    match /payroll_payments/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if true;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isValidId(categoryId) && isValidFinancialCategory(incoming());
      allow delete: if true;
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow create, update: if isValidId(partnerId) && isValidPartner(incoming());
      allow delete: if true;
    }

    match /donations/{donationId} {
      allow read: if true;
      allow create, update: if isValidId(donationId) && isValidDonation(incoming());
      allow delete: if true;
    }

    match /staff/{staffId} {
      allow read: if true;
      allow create, update: if isValidId(staffId) && isValidStaff(incoming());
      allow delete: if true;
    }

    match /salaries/{nik} {
      allow read: if true;
      allow create, update: if isValidId(nik) && isValidSalary(incoming());
      allow delete: if true;
    }

    match /inward_letters/{letterId} {
      allow read: if true;
      allow create, update: if isValidId(letterId) && isValidLetterInward(incoming());
      allow delete: if true;
    }

    match /outward_letters/{letterId} {
      allow read: if true;
      allow create, update: if isValidId(letterId) && isValidLetterOutward(incoming());
      allow delete: if true;
    }

    match /documents/{documentId} {
      allow read: if true;
      allow create, update: if isValidId(documentId) && isValidOrgDocument(incoming());
      allow delete: if true;
    }

    match /approvals/{approvalId} {
      allow read: if true;
      allow create, update: if isValidId(approvalId) && isValidApproval(incoming());
      allow delete: if true;
    }

    match /audits/{auditId} {
      allow read: if true;
      allow create, update: if isValidId(auditId) && isValidAudit(incoming());
      allow delete: if true;
    }

    match /kas/{recordId} {
      allow read: if true;
      allow create, update: if isValidId(recordId) && isValidKas(incoming());
      allow delete: if true;
    }

    match /detail_pengeluaran/{detailId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /detail_expenses/{detailId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /structures/{structureId} {
      allow read: if true;
      allow create, update: if isValidId(structureId) && isValidStructure(incoming());
      allow delete: if true;
    }

    match /system_state/{stateId} {
      allow read: if true;
      allow create, update, delete: if true;
    }
  }
}
