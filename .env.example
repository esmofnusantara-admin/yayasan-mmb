# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DB_PROVIDER: Database backend used by server.ts.
# - firebase (default): Uses firebase-applet-config.json + Firestore
# - json: Uses a local JSON file as lightweight storage
# - postgres: Uses a PostgreSQL-compatible database (Railway, Supabase, Neon, etc.)
DB_PROVIDER="firebase"

# JSON_DB_PATH: Path for local JSON database file when DB_PROVIDER=json.
JSON_DB_PATH="./data/local-db.json"

# DATABASE_URL: PostgreSQL connection string when DB_PROVIDER=postgres.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
